---
import { getCardsForCategory, mirrorCards, type CardCategory } from '../data/cards';
import ReadingResult from './ReadingResult.astro';

type ReadingQuestion = {
  id: string;
  label: string;
  category: CardCategory;
  prompt: string;
  placeholder: string;
  comfortFrame: string;
  windowFrame: string;
  mirrorFrame: string;
  actionFrame: string;
};

type Props = {
  category?: CardCategory;
  compact?: boolean;
};

const { category = 'general', compact = false } = Astro.props;
const cards = getCardsForCategory(category).slice(0, 6);
const fallbackCard = cards[0];
const questions: ReadingQuestion[] = [
  {
    id: 'feelings',
    label: 'What do they feel about me?',
    category: 'feelings',
    prompt: 'Look at what their signals may be showing and what you hope their feelings will fix.',
    placeholder: 'What do they feel about me?',
    comfortFrame: 'It makes sense that you want their feelings to become clearer.',
    windowFrame: 'For this question, the card points to the difference between feeling and capacity.',
    mirrorFrame: 'It also asks what you hope their feelings would finally prove about you.',
    actionFrame: 'Before you search for another sign, compare this reading with their consistent behavior.',
  },
  {
    id: 'missing',
    label: 'Do they miss me?',
    category: 'missing',
    prompt: 'Explore silence, longing, and the need to know whether the connection still matters.',
    placeholder: 'Do they miss me during this silence?',
    comfortFrame: 'It makes sense that silence makes you reach for reassurance.',
    windowFrame: 'For this question, the card treats silence as information, not proof.',
    mirrorFrame: 'It also asks why being missed would feel like relief right now.',
    actionFrame: 'Let this answer support reflection, not another round of checking or chasing.',
  },
  {
    id: 'texting',
    label: 'Should I text them?',
    category: 'texting',
    prompt: 'Separate honest communication from the urge to chase reassurance.',
    placeholder: 'Should I text them or wait?',
    comfortFrame: 'It makes sense that one message can feel like it carries the whole connection.',
    windowFrame: 'For this question, the card looks at whether contact would create clarity or restart the loop.',
    mirrorFrame: 'It also asks whether the urge to text is expression, repair, or anxiety seeking relief.',
    actionFrame: 'Write the message first, then decide whether it still feels clear after the intensity drops.',
  },
  {
    id: 'waiting',
    label: 'Should I wait or let go?',
    category: 'waiting',
    prompt: 'Notice whether waiting is hope, fear, loyalty, or avoidance.',
    placeholder: 'Should I keep waiting, or is it time to let go?',
    comfortFrame: 'It makes sense that letting go feels difficult when part of you still sees possibility.',
    windowFrame: 'For this question, the card looks at whether there is movement you can actually see.',
    mirrorFrame: 'It also asks what waiting protects you from feeling or choosing.',
    actionFrame: 'Set one boundary around how long uncertainty is allowed to organize your day.',
  },
  {
    id: 'anxiety',
    label: 'Why can’t I stop thinking about them?',
    category: 'anxiety',
    prompt: 'Read the emotional loop underneath the repeating thought.',
    placeholder: 'Why can’t I stop thinking about them?',
    comfortFrame: 'It makes sense that your mind keeps returning to what still feels unfinished.',
    windowFrame: 'For this question, the card does not treat repetition as destiny.',
    mirrorFrame: 'It also asks what feeling the thought keeps returning to solve.',
    actionFrame: 'Name the feeling under the thought before treating the thought as a sign.',
  },
];
const initialQuestion = questions.find((question) => question.category === category) ?? questions[0];
---

<section
  class:list={['card-draw', compact && 'is-compact']}
  data-card-draw
  data-cards={JSON.stringify(cards)}
  data-all-cards={JSON.stringify(mirrorCards)}
  data-questions={JSON.stringify(questions)}
>
  <div class="card-draw-copy">
    <p class="eyebrow">AI-assisted mirror reading</p>
    <h2>What question keeps coming back?</h2>
    <p>
      Type the relationship question on your mind, then choose a card for comfort, reflection, and one grounded next step.
    </p>
  </div>

  <label class="question-input-label" for="mirror-question">Your question</label>
  <textarea
    id="mirror-question"
    class="question-input"
    data-question-input
    maxlength="300"
    rows="3"
    placeholder={initialQuestion.placeholder}
  >{initialQuestion.label}</textarea>
  <p class="privacy-hint">
    Do not enter names, phone numbers, addresses, or private identifying details.
  </p>

  <div class="reading-steps" aria-label="Reading steps">
    <span>1. Ask your question</span>
    <span>2. Pick one card</span>
    <span>3. Receive comfort and clarity</span>
  </div>

  <p class="selector-label">Or begin with one of these:</p>
  <div class="question-selector" data-question-selector role="radiogroup" aria-label="Choose your relationship question">
    {questions.map((question) => (
      <button
        class:list={['question-chip', question.id === initialQuestion.id && 'is-selected']}
        type="button"
        role="radio"
        aria-checked={question.id === initialQuestion.id ? 'true' : 'false'}
        data-question-id={question.id}
        data-question-category={question.category}
      >
        <span>{question.label}</span>
        <small>{question.prompt}</small>
      </button>
    ))}
  </div>

  <div class="card-options" role="group" aria-label="Choose one card for your reading">
    {[0, 1, 2].map((index) => (
      <button class="tarot-card-back" type="button" data-card-index={index}>
        <span class="card-number">0{index + 1}</span>
        <span class="card-sigil" aria-hidden="true"></span>
        <span class="card-label">Mirror</span>
      </button>
    ))}
  </div>

  <div class="reading-result-shell">
    <ReadingResult card={fallbackCard} questionLabel={initialQuestion.label} hidden />
  </div>

  <script is:inline>
    document.querySelectorAll('[data-card-draw]').forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      const defaultCards = JSON.parse(root.dataset.cards || '[]');
      const allCards = JSON.parse(root.dataset.allCards || '[]');
      const questions = JSON.parse(root.dataset.questions || '[]');
      const buttons = Array.from(root.querySelectorAll('[data-card-index]'));
      const questionButtons = Array.from(root.querySelectorAll('[data-question-id]'));
      const questionInput = root.querySelector('[data-question-input]');
      const result = root.querySelector('[data-reading-result]');
      let selectedQuestion = questions.find((question) => question.category === defaultCards[0]?.categories?.[0]) || questions[0];

      const setText = (selector, value) => {
        const element = result?.querySelector(selector);
        if (element) element.textContent = value;
      };

      const fallbackReading = (card, userQuestion) => ({
        comfort: `${selectedQuestion.comfortFrame} You are allowed to want tenderness before you try to be clear.`,
        window: `${selectedQuestion.windowFrame} ${card.window}`,
        mirror: `${selectedQuestion.mirrorFrame} ${card.mirror}`,
        action: `${selectedQuestion.actionFrame} ${card.action}`,
        source: 'Mirror fallback reading',
        note: 'The AI reading is unavailable right now, so this is a grounded Mirror Tarot fallback.',
        question: userQuestion,
      });

      const applyReading = (card, reading) => {
        setText('[data-selected-question]', reading.question || selectedQuestion.label);
        setText('[data-card-name]', card.name);
        setText('[data-card-hook]', card.hook);
        setText('[data-card-comfort]', reading.comfort);
        setText('[data-card-window]', reading.window);
        setText('[data-card-mirror]', reading.mirror);
        setText('[data-card-action]', reading.action);
        setText('[data-reading-source]', reading.source || 'AI-assisted Mirror reading');
        setText('[data-reading-note]', reading.note || 'This reading is for entertainment and self-reflection, not professional advice or a guaranteed prediction.');
      };

      const cardsForQuestion = () => {
        const filtered = allCards.filter((card) => card.categories?.includes(selectedQuestion.category));
        return filtered.length > 0 ? filtered : defaultCards;
      };

      const readUserQuestion = () => {
        const value = questionInput instanceof HTMLTextAreaElement ? questionInput.value.trim() : '';
        return value.slice(0, 300) || selectedQuestion.label;
      };

      const requestAiReading = async (card, userQuestion) => {
        const response = await fetch('/api/reading', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            question: userQuestion,
            category: selectedQuestion.category,
            card,
            context: {
              selectedPrompt: selectedQuestion.prompt,
              pagePath: window.location.pathname,
            },
          }),
        });

        const payload = await response.json();
        if (!payload?.reading) {
          throw new Error('AI reading response was empty');
        }

        if (!response.ok && !payload.reading) {
          throw new Error('AI reading request failed');
        }

        const sourceLabel = {
          ai: 'AI-assisted Mirror reading',
          safety: 'Safety-first reflection',
          fallback: 'Mirror fallback reading',
        }[payload.source] || 'Mirror fallback reading';

        return {
          ...payload.reading,
          source: sourceLabel,
          note: payload.note,
          question: userQuestion,
        };
      };

      questionButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const questionId = button.getAttribute('data-question-id');
          selectedQuestion = questions.find((question) => question.id === questionId) || questions[0];
          if (questionInput instanceof HTMLTextAreaElement) {
            questionInput.value = selectedQuestion.placeholder || selectedQuestion.label;
          }
          questionButtons.forEach((item) => {
            item.classList.remove('is-selected');
            item.setAttribute('aria-checked', 'false');
          });
          button.classList.add('is-selected');
          button.setAttribute('aria-checked', 'true');
          buttons.forEach((item) => item.classList.remove('is-selected', 'is-dimmed', 'is-revealed'));
          result?.classList.add('is-hidden');
        });
      });

      buttons.forEach((button, index) => {
        button.addEventListener('click', async () => {
          const cards = cardsForQuestion();
          const card = cards[(index + Math.floor(Math.random() * cards.length)) % cards.length];
          const userQuestion = readUserQuestion();
          buttons.forEach((item) => {
            item.classList.remove('is-selected', 'is-revealed');
            item.classList.add('is-dimmed');
          });
          button.classList.remove('is-dimmed');
          button.classList.add('is-selected', 'is-revealed');
          applyReading(card, {
            ...fallbackReading(card, userQuestion),
            source: 'Preparing your reading...',
            note: 'Hold the question gently while the reading forms.',
          });
          result?.classList.remove('is-hidden');
          result?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

          try {
            const reading = await requestAiReading(card, userQuestion);
            applyReading(card, reading);
          } catch (error) {
            applyReading(card, fallbackReading(card, userQuestion));
          }
        });
      });
    });
  </script>
</section>
