---
import BaseLayout from '../layouts/BaseLayout.astro';
import CardDraw from '../components/CardDraw.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import { getPageBySlug, getRelatedPages, sitePages } from '../data/pages';

const page = getPageBySlug('/');

if (!page) {
  throw new Error('Home page data is missing');
}

const featuredPages = sitePages.filter((item) =>
  ['/does-he-miss-me-tarot/', '/should-i-text-him/', '/what-do-they-feel-about-me/', '/relationship-anxiety-or-gut-feeling/'].includes(item.slug),
);
const relatedPages = getRelatedPages(page);
---

<BaseLayout title={page.title} description={page.description} canonicalPath="/">
  <section class="ritual-hero">
    <div class="home-shell ritual-hero-grid">
      <div class="home-hero">
        <p class="eyebrow">Private relationship reading</p>
        <h1>Choose a card for the question you keep asking about them.</h1>
        <p class="lede">
          Mirror Tarot turns love uncertainty into a two-part reading: what the connection may be
          showing, and what the question reveals inside you.
        </p>
        <div class="hero-actions">
          <a class="button" href="/love-tarot-reading/">Start the reading</a>
          <a class="button secondary" href="/does-he-miss-me-tarot/">Choose a relationship question</a>
        </div>
      </div>

      <CardDraw category="general" compact />
    </div>
  </section>

  <section class="home-shell section-band">
    <div class="section-heading">
      <p class="eyebrow">Start with the ache</p>
      <h2>Questions people ask when uncertainty gets loud.</h2>
    </div>

    <section class="feature-grid question-grid" aria-label="Featured relationship questions">
      {featuredPages.map((item) => (
        <a class="feature-card" href={item.slug}>
          <span>{item.eyebrow}</span>
          <strong>{item.heading}</strong>
          <p>{item.description}</p>
        </a>
      ))}
    </section>

    <section class="method-panel">
      <h2>The Window and the Mirror</h2>
      <p>
        The Window looks toward the relationship question you arrived with. The Mirror looks at
        what that question may be asking from inside you.
      </p>
    </section>
  </section>

  <RelatedLinks pages={relatedPages} heading="Start here" />
</BaseLayout>
