---
import ArticleLayout from './ArticleLayout.astro';
import CardDraw from '../components/CardDraw.astro';
import type { SitePage } from '../data/pages';

type Props = {
  page: SitePage;
};

const { page } = Astro.props;
---

<ArticleLayout page={page}>
  <slot name="before-sections" slot="before-sections" />
  <CardDraw slot="reading" category={page.category} />
  <slot />
</ArticleLayout>
